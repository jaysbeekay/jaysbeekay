# Example nginx reverse-proxy config that puts the Contracts app behind
# mutual TLS (mTLS): nginx terminates TLS and requires every client to
# present a certificate signed by your own private CA. Requests without
# one are rejected by nginx before they ever reach the app.
#
# This file is a template, not something you can drop in unmodified —
# replace server_name and the cert/key paths, then reload nginx:
#   nginx -t && systemctl reload nginx
#
# See the "Locking down access with mTLS" section in the main README for
# how to generate client-ca.crt and per-client certificates.

upstream contracts_app {
    # The Contracts container, published to localhost only (see README).
    server 127.0.0.1:3000;
}

server {
    listen 80;
    listen [::]:80;
    server_name contracts.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name contracts.example.com;

    # Server certificate for contracts.example.com (e.g. from Let's Encrypt).
    # Unrelated to the client CA below.
    ssl_certificate     /etc/nginx/ssl/contracts.example.com.crt;
    ssl_certificate_key /etc/nginx/ssl/contracts.example.com.key;

    # --- mTLS: require a client certificate signed by your private CA ---
    ssl_client_certificate /etc/nginx/ssl/client-ca.crt;
    ssl_verify_client on;
    ssl_verify_depth 2;

    location / {
        proxy_pass http://contracts_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
