# SQLite database file (relative to the project root / container workdir)
DATABASE_URL="file:./data/app.db"

# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL the app is served from (used in links, cookies, etc.)
APP_URL="http://localhost:3000"

# Set to "true" when running behind a reverse proxy (e.g. nginx) so
# NextAuth trusts the proxied Host header. See README "Locking down
# access with nginx + mTLS" for a full reverse-proxy setup.
AUTH_TRUST_HOST=""

# Where uploaded contract documents are stored
UPLOADS_DIR="./data/uploads"

# Default reminder thresholds (days before expiry) for new contracts
REMINDER_DEFAULT_DAYS="30,14,7,1"

# Cron schedule for the built-in expiration check (node-cron syntax)
REMINDER_CRON_SCHEDULE="0 8 * * *"

# Email (SMTP) reminders — leave SMTP_HOST/SMTP_USER blank to disable
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Contracts <no-reply@localhost>"

# Push reminders via ntfy — leave NTFY_TOPIC blank to disable
NTFY_URL="https://ntfy.sh"
NTFY_TOPIC=""
NTFY_TOKEN=""

# Optional: protects POST /api/cron for triggering the expiration check
# from an external scheduler instead of (or in addition to) the built-in
# one. Leave unset to disable the endpoint entirely (it 404s).
CRON_SECRET=""

# Optional: enables GET/POST /api/mcp, a read-only Model Context Protocol
# server for querying contracts from a local LLM agent (e.g. Ollama). Leave
# unset to disable the endpoint entirely (it 404s). See README "Querying
# contracts from an LLM (MCP)".
MCP_TOKEN=""

# Optional: set both to let document auto-fill (when adding a new contract)
# fall back to your local Ollama server for field extraction when the
# built-in heuristics can't confidently parse a scanned document. Leave
# either blank to skip this fallback (heuristics-only). See README
# "Auto-filling fields from a document".
OLLAMA_BASE_URL=""
OLLAMA_MODEL=""

# Optional: set to "true" to let scanning a product's barcode (in the
# "Add product" form) look up its name/brand from UPCitemdb so you don't
# have to type them in. Leave unset/false to disable — the barcode itself
# is still captured and saved, just without the online lookup. Uses the
# free, keyless trial endpoint (rate-limited per IP) unless
# BARCODE_LOOKUP_API_KEY is set. See README "Barcode scanning for
# products".
BARCODE_LOOKUP_ENABLED=""
BARCODE_LOOKUP_API_KEY=""

# Required to enable "bring your own key" AI document extraction (Settings
# page), and also required (see below) to enable offsite database backups.
# Encrypts each user's API key at rest, and every backup before upload, with
# AES-256-GCM. Generate with: openssl rand -base64 32
# Leave blank to disable both features (the AI Settings section is hidden,
# extraction falls back to local heuristics/Ollama, and backups stay
# disabled). See README "Bring your own AI key".
ENCRYPTION_KEY=""

# Offsite database backups — requires ENCRYPTION_KEY above (backups are
# always encrypted before upload, never sent in the clear). Configure
# BACKUP_S3_*, BACKUP_SFTP_*, both, or neither — each destination is
# independently enabled by its own variables being set, and a scheduled
# backup runs to every configured destination. See README "Database
# backups".
BACKUP_CRON_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_COUNT="7"

# S3-compatible storage (AWS S3, Backblaze B2, Cloudflare R2, MinIO, etc.)
# Leave BACKUP_S3_BUCKET blank to disable this destination.
BACKUP_S3_ENDPOINT=""
BACKUP_S3_REGION="auto"
BACKUP_S3_BUCKET=""
BACKUP_S3_ACCESS_KEY_ID=""
BACKUP_S3_SECRET_ACCESS_KEY=""
BACKUP_S3_FORCE_PATH_STYLE="false"

# SFTP. Leave BACKUP_SFTP_HOST blank to disable this destination. Use
# either BACKUP_SFTP_PASSWORD or BACKUP_SFTP_PRIVATE_KEY (a PEM-format
# private key), not necessarily both.
BACKUP_SFTP_HOST=""
BACKUP_SFTP_PORT="22"
BACKUP_SFTP_USERNAME=""
BACKUP_SFTP_PASSWORD=""
BACKUP_SFTP_PRIVATE_KEY=""
BACKUP_SFTP_REMOTE_PATH="/backups"
