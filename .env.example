# SQLite database file (relative to the project root / container workdir)
DATABASE_URL="file:./data/app.db"

# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL the app is served from (used in links, cookies, etc.)
APP_URL="http://localhost:3000"

# Set to "true" when running behind a reverse proxy (e.g. nginx) so
# NextAuth trusts the proxied Host header. See README "Locking down
# access with nginx + mTLS" for a full reverse-proxy setup.
AUTH_TRUST_HOST=""

# Where uploaded contract documents are stored
UPLOADS_DIR="./data/uploads"

# Default reminder thresholds (days before expiry) for new contracts
REMINDER_DEFAULT_DAYS="30,14,7,1"

# Cron schedule for the built-in expiration check (node-cron syntax)
REMINDER_CRON_SCHEDULE="0 8 * * *"

# Email (SMTP) reminders — leave SMTP_HOST/SMTP_USER blank to disable
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Contracts <no-reply@localhost>"

# Push reminders via ntfy — leave NTFY_TOPIC blank to disable
NTFY_URL="https://ntfy.sh"
NTFY_TOPIC=""
NTFY_TOKEN=""

# Optional: protects POST /api/cron for triggering the expiration check
# from an external scheduler instead of (or in addition to) the built-in
# one. Leave unset to disable the endpoint entirely (it 404s).
CRON_SECRET=""
